# GolPeão — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Banco de dados
DATABASE_URL=sqlite:///./golpeao.db
# Para produção (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/golpeao

# JWT
SECRET_KEY=troque-por-uma-chave-secreta-de-256-bits-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin
ADMIN_SECRET=chave-para-criar-usuarios-admin

# Ambiente
ENVIRONMENT=development
# ENVIRONMENT=production

# Frontend (Streamlit)
API_BASE_URL=http://localhost:8000

# Timezone de exibição (horário de Brasília)
DISPLAY_TIMEZONE=America/Recife
